# Copy to ~/.config/devin/mimo.env and fill in your key.
# Used by claude-mimo-ultracode launchers.

DEVIN_MIMO_API_KEY=your-mimo-api-key-here
DEVIN_MIMO_BASE=https://token-plan-sgp.xiaomimimo.com/v1
DEVIN_MIMO_MODEL=mimo-v2.5-pro
DEVIN_MIMO_MAX_OUTPUT_TOKENS=131072
DEVIN_MIMO_REQUEST_MAX_TOKENS=8192
DEVIN_MIMO_ENABLE_THINKING=0
DEVIN_MIMO_TIMING_LOG=1
