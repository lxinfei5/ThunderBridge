# UltraCode-Shim secrets / tunables.
#
# Copy this file to `ultracode.env` (gitignored) and fill in ONLY the keys for
# the plans you actually have. The launcher loads this before starting the proxy,
# and ultracode_slots.json references these as ${VAR} so keys never get committed.

# --- API-key backends (referenced by ${VAR} in ultracode_slots.json) ---------
MIMO_API_KEY=
DEEPSEEK_API_KEY=
STEPFUN_API_KEY=
OLLAMA_API_KEY=
OPENROUTER_API_KEY=
OPENCODE_API_KEY=
OPENAI_API_KEY=
# Local servers (Ollama/llama.cpp/LM Studio) usually ignore the key; any value works.
LOCAL_API_KEY=local

# GPT-5.5 (codex_oauth) needs no key here - run `codex login` once instead.

# --- Proxy tunables (optional; defaults are fine) ----------------------------
# UC_LISTEN_PORT=8141
# UC_MAX_TOKENS=64000
# UC_VERBOSE=0
# Codex reasoning effort / tier (codex_oauth slots):
# UC_CODEX_EFFORT=medium
# UC_CODEX_SERVICE_TIER=
