#!/usr/bin/env bash
set -euo pipefail

export CLAUDE_COMPOSER_ULTRACODE_PORT="${CLAUDE_COMPOSER_ULTRACODE_PORT:-18767}"
export CLAUDE_COMPOSER_ULTRACODE_BACKEND="${CLAUDE_COMPOSER_ULTRACODE_BACKEND:-composer-2.5-fast}"

printf '\033]0;Composer 2.5 Fast UltraCode\007'

if [[ "${1:-}" == "--smoke" ]]; then
  shift
  exec claude-composer-ultracode --smoke "${*:-Say only VIDEO_COMPOSER_OK}"
fi

exec claude-composer-ultracode \
  --name "Composer 2.5 Fast UltraCode" \
  --append-system-prompt "For this session, when asked what backend model is running, answer: Composer 2.5 Fast via local UltraCode shim." \
  "$@"
