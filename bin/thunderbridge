#!/usr/bin/env bash
# ThunderBridge — bridge Claude Code UltraCode mode to third-party models.
#
# Usage:
#   thunderbridge                       interactive (default: config.astockos.json)
#   thunderbridge -p "prompt"           headless batch (same proxy + envelope)
#   thunderbridge --profile deepseek    use config.deepseek.json
#   thunderbridge --profile maas        use config.maas.json
#   thunderbridge --config custom.json  custom config file
#   thunderbridge --upstream URL        override upstream
#
# What it does:
#   1. Starts proxy.py on a dynamic port (OS-assigned — worktree-safe)
#   2. Injects UltraCode envelope: effort=xhigh + max_tokens=64000 + thinking=adaptive
#   3. Passes through to your Anthropic-compatible upstream — no protocol translation
#   4. Cleans up proxy on exit (trap EXIT)
#
# Your normal `claude` command is untouched — this is opt-in via --settings isolation.
#
# Env vars (all optional):
#   THUNDER_CONFIG     config.json path (default: config.astockos.json → config.json)
#   THUNDER_UPSTREAM   upstream URL override
#   UC_MAX_TOKENS      override max_tokens floor (default: 64000)
#   UC_FORCE_EFFORT=0  disable effort=xhigh injection
#   UC_FORCE_THINKING=0 disable thinking=adaptive injection
set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve repo root through symlinks
# ---------------------------------------------------------------------------
SELF="${BASH_SOURCE[0]}"
while [ -h "$SELF" ]; do
  DIR="$(cd -P "$(dirname "$SELF")" && pwd)"
  SELF="$(readlink "$SELF")"
  case "$SELF" in /*) ;; *) SELF="$DIR/$SELF" ;; esac
done
REPO="$(cd -P "$(dirname "$SELF")/.." && pwd)"

PROXY="$REPO/proxy.py"
BASE_STATE="${XDG_STATE_HOME:-$HOME/.local/state}/thunderbridge"
mkdir -p "$BASE_STATE"
chmod 700 "$BASE_STATE" 2>/dev/null || true

# ---------------------------------------------------------------------------
# Parse ThunderBridge own flags (conSUmed, not forwarded to claude).
# Forward --dangerously-skip-permissions and everything unknown to claude.
# ---------------------------------------------------------------------------
PROFILE=""
CFG="${THUNDER_CONFIG:-}"
CLAUDE_ARGS=()
while [ $# -gt 0 ]; do
  case "$1" in
    --profile)
      PROFILE="${2:?--profile needs a name (e.g. deepseek, maas, astockos)}"; shift 2 ;;
    --profile=*)
      PROFILE="${1#*=}"; shift ;;
    --config)
      CFG="${2:?--config needs a path}"; shift 2 ;;
    --config=*)
      CFG="${1#*=}"; shift ;;
    --upstream)
      THUNDER_UPSTREAM="${2:?--upstream needs a URL}"; shift 2 ;;
    --upstream=*)
      THUNDER_UPSTREAM="${1#*=}"; shift ;;
    -p)
      CLAUDE_ARGS+=("-p"); shift ;;               # -p is for claude, forward it
    --dangerously-skip-permissions|--worktree)    # claude flags, forward
      CLAUDE_ARGS+=("$1"); shift ;;
    *)
      CLAUDE_ARGS+=("$1"); shift ;;
  esac
done

# ---------------------------------------------------------------------------
# Config resolution: --config > --profile > THUNDER_CONFIG > config.astockos.json > config.json
# ---------------------------------------------------------------------------
if [ -n "$PROFILE" ] && [ -z "${THUNDER_CONFIG:-}" ]; then
  PROFILE_CFG="$REPO/config.${PROFILE}.json"
  if [ -f "$PROFILE_CFG" ]; then
    CFG="$PROFILE_CFG"
  else
    echo "ThunderBridge: profile '$PROFILE' not found ($PROFILE_CFG)" >&2
    echo "  Available profiles:" >&2
    for f in "$REPO"/config.*.json; do
      [ -f "$f" ] || continue
      name="$(basename "$f" .json | sed 's/^config\.//')"
      [ -z "$name" ] && continue  # skip config.json itself (not a profile)
      [ "$name" = "example" ] && continue  # skip config.example.json
      desc="$(python3 -c "import json; c=json.load(open('$f')); print(c.get('_comment','')[:80])" 2>/dev/null || true)"
      printf '    %-16s %s\n' "$name" "$desc" >&2
    done
    exit 1
  fi
fi
if [ -z "$CFG" ]; then
  if [ -f "$REPO/config.astockos.json" ]; then
    CFG="$REPO/config.astockos.json"
  elif [ -f "$REPO/config.json" ]; then
    CFG="$REPO/config.json"
  fi
fi

# ---------------------------------------------------------------------------
# Prerequisites
# ---------------------------------------------------------------------------
PY="$(command -v python3 || command -v python || true)"
[ -n "$PY" ] || {
  echo "ThunderBridge: Python 3 not found." >&2; exit 1; }

command -v claude >/dev/null 2>&1 || {
  echo "ThunderBridge: claude CLI not found." >&2
  echo "  Install: npm i -g @anthropic-ai/claude-code" >&2
  exit 1; }

# ---------------------------------------------------------------------------
# Upstream resolution (first-wins):
#   THUNDER_UPSTREAM > config proxy.anthropic_upstream > ANTHROPIC_BASE_URL
# ---------------------------------------------------------------------------
cfg_upstream() {
  "$PY" -c "
import json,sys
c=json.load(open(sys.argv[1]))
print((c.get('proxy') or {}).get('anthropic_upstream',''))
" "$CFG" 2>/dev/null || true
}

UPSTREAM="${THUNDER_UPSTREAM:-}"
if [ -z "$UPSTREAM" ] && [ -f "$CFG" ]; then
  UPSTREAM="$(cfg_upstream)"
fi
UPSTREAM="${UPSTREAM:-${ANTHROPIC_BASE_URL:-https://api.anthropic.com}}"

# ---------------------------------------------------------------------------
# Per-instance state files (suffix = this launcher's PID, unique per run).
# Fixes the shared-file race: concurrent thunderbridge launches used to
# clobber each other's proxy.port / settings.json, baking a session onto
# ANOTHER session's port — and when that other session exited and cleaned
# up its proxy, the orphaned session got ConnectionRefused. (cmux reads
# whatever --settings path we pass, so a per-instance filename is safe.)
# ---------------------------------------------------------------------------
INST="$$"
PORT_FILE="$BASE_STATE/proxy.$INST.port"
PID_FILE="$BASE_STATE/proxy.$INST.pid"
SETTINGS_FILE="$BASE_STATE/settings.$INST.json"
LOG_FILE="$BASE_STATE/proxy.log"            # shared append log (intentional)
SELECTION_FILE="$BASE_STATE/selection.json" # shared model-selection cache (intentional)

PROXY_PID=""
SUPERVISOR_PID=""

# ---------------------------------------------------------------------------
# Reap orphaned proxies from prior sessions whose wrapper was hard-killed
# (SIGKILL) before its EXIT trap could fire → proxy.py reparented to init
# (PPID=1). Only proxy.py procs whose parent is init are killed: a live
# session's proxy still has its wrapper bash as parent, so it is untouched.
# Also drops stale per-instance pid/port files whose pid is no longer alive.
# ---------------------------------------------------------------------------
reap_orphans() {
  for pf in "$BASE_STATE"/proxy.*.pid; do
    [ -f "$pf" ] || continue
    p="$(cat "$pf" 2>/dev/null)" || p=""
    if [ -z "$p" ] || ! kill -0 "$p" 2>/dev/null; then
      rm -f "$pf" "${pf%.pid}.port"
    fi
  done
  ps -xo pid,ppid,command 2>/dev/null \
    | awk '$2==1 && /proxy\.py/ {print $1}' 2>/dev/null \
    | while read -r opid; do
        [ -z "$opid" ] && continue
        echo "[ThunderBridge] reaping orphaned proxy pid $opid (PPID=1)" >> "$LOG_FILE" 2>/dev/null || true
        kill "$opid" 2>/dev/null || true
      done || true
}
reap_orphans

cleanup() {
  [ -n "${SUPERVISOR_PID:-}" ] && kill "$SUPERVISOR_PID" 2>/dev/null || true
  [ -f "$PID_FILE" ] && kill "$(cat "$PID_FILE" 2>/dev/null)" 2>/dev/null || true
  [ -n "${PROXY_PID:-}" ] && kill "$PROXY_PID" 2>/dev/null || true
  rm -f "$PID_FILE" "$PORT_FILE" "$SETTINGS_FILE"
}
trap cleanup EXIT

# ---------------------------------------------------------------------------
# Pre-reserve a free loopback port IN THE LAUNCHER (not the proxy). The
# launcher then KNOWS the port with no shared-file read → no race; and a
# supervisor can restart the proxy on the SAME port (claude has this port
# baked into its settings, so it recovers on its next retry, no re-launch).
# ---------------------------------------------------------------------------
PORT="$("$PY" -c '
import socket
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.bind(("127.0.0.1", 0))
print(s.getsockname()[1])
s.close()
')" || { echo "ThunderBridge: failed to reserve a free port." >&2; exit 1; }
BASE_URL="http://127.0.0.1:$PORT"

# (Re)start the proxy on the fixed $PORT. Updates PROXY_PID + PID_FILE.
start_proxy() {
  UC_CONFIG="$CFG" \
    UC_LISTEN_PORT="$PORT" \
    UC_PORT_FILE="$PORT_FILE" \
    UC_UPSTREAM="$UPSTREAM" \
    UC_SELECTION_CACHE="$SELECTION_FILE" \
    "$PY" "$PROXY" >>"$LOG_FILE" 2>&1 &
  PROXY_PID=$!
  echo "$PROXY_PID" > "$PID_FILE"
}

# Health check against the known $PORT.
health_ok() {
  "$PY" -c "
import json,urllib.request
try:
    with urllib.request.urlopen(
        'http://127.0.0.1:$PORT/healthz', timeout=2
    ) as r:
        assert json.loads(r.read()).get('ok')
except: exit(1)
" 2>/dev/null
}

# ---------------------------------------------------------------------------
# Start proxy + wait for health (fail fast if it died on bind).
# ---------------------------------------------------------------------------
echo "ThunderBridge: starting proxy -> $UPSTREAM"
start_proxy
proxy_ready=0
for _ in $(seq 1 40); do
  if health_ok; then proxy_ready=1; break; fi
  kill -0 "$PROXY_PID" 2>/dev/null || break   # proxy exited during startup
  sleep 0.25
done
if [ "$proxy_ready" -ne 1 ]; then
  echo "ThunderBridge: proxy failed to start on $BASE_URL. Log:" >&2
  tail -20 "$LOG_FILE" >&2 || true
  exit 1
fi
echo "ThunderBridge: proxy ready on $BASE_URL (pid $PROXY_PID)"

# ---------------------------------------------------------------------------
# Session-scoped settings (per-instance path; carries only this port).
# ---------------------------------------------------------------------------
SETTINGS_TMP="$(umask 077; mktemp "$BASE_STATE/.settings.XXXXXX")"
cat > "$SETTINGS_TMP" <<JSON
{
  "env": {
    "ANTHROPIC_BASE_URL": "$BASE_URL",
    "CLAUDE_CODE_WORKFLOWS": "1",
    "CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY": "1"
  }
}
JSON
chmod 600 "$SETTINGS_TMP" 2>/dev/null || true
mv -f "$SETTINGS_TMP" "$SETTINGS_FILE"

# ---------------------------------------------------------------------------
# Seed gateway-models cache (so /model works immediately without fetch)
# ---------------------------------------------------------------------------
CFG_CACHE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/cache"
mkdir -p "$CFG_CACHE_DIR"
"$PY" - "$CFG_CACHE_DIR/gateway-models.json" "$BASE_URL" <<'PY' || true
import json,os,sys,time,urllib.request
cache_f, base = sys.argv[1], sys.argv[2]
try:
    with urllib.request.urlopen(base.rstrip('/')+'/healthz',timeout=2) as r:
        health = json.loads(r.read().decode('utf-8'))
    models, seen = [], set()
    for key in ('stock_models','custom_models'):
        for m in health.get(key) or []:
            if isinstance(m,dict) and m.get('id') and m['id'] not in seen:
                seen.add(m['id'])
                models.append({
                    'id': m['id'],
                    'display_name': m.get('display_name', m['id']),
                })
    json.dump({
        'baseUrl': base,
        'fetchedAt': int(time.time() * 1000),
        'models': models,
    }, open(cache_f, 'w'))
except: pass
PY

# ---------------------------------------------------------------------------
# Supervise: if the proxy dies while the session is live, restart it on the
# SAME pre-reserved port (claude recovers on its next retry). Runs in the
# background; ignores INT/TERM so an interactive Ctrl+C (handled by claude,
# which stays in the foreground) doesn't take the supervisor down. Restarts
# are capped to avoid a crash-loop. cleanup() (EXIT trap) kills it on exit.
# ---------------------------------------------------------------------------
MAX_RESTARTS=5
supervise() {
  set +e
  trap '' INT TERM
  count=0
  while [ -f "$PID_FILE" ]; do
    sleep 2
    [ -f "$PID_FILE" ] || return 0
    if ! kill -0 "$PROXY_PID" 2>/dev/null; then
      if [ "$count" -ge "$MAX_RESTARTS" ]; then
        echo "[ThunderBridge] proxy died; restart cap ($MAX_RESTARTS) reached — leaving it down." >> "$LOG_FILE" 2>/dev/null || true
        return 0
      fi
      count=$((count + 1))
      echo "[ThunderBridge] proxy pid $PROXY_PID died — restarting on $PORT (attempt $count/$MAX_RESTARTS)" >> "$LOG_FILE" 2>/dev/null || true
      start_proxy
      for _ in $(seq 1 20); do health_ok && break; sleep 0.25; done
    fi
  done
}
supervise &
SUPERVISOR_PID=$!

# ---------------------------------------------------------------------------
# Launch Claude in the FOREGROUND (so Ctrl+C / interactive signals behave
# exactly as before — claude handles them, the shell keeps waiting). The
# shell survives claude so the EXIT trap fires and cleanup() tears down the
# proxy + supervisor. NOT exec'd.
# ---------------------------------------------------------------------------
echo "ThunderBridge: launching Claude Code (UltraCode envelope active)"
echo "  Proxy:     $BASE_URL -> $UPSTREAM (supervised: same-port restart on death)"
[ -n "$PROFILE" ] && echo "  Profile:   $PROFILE ($(python3 -c "import json; c=json.load(open('$CFG')); print(c.get('_comment','')[:60])" 2>/dev/null || echo "$CFG"))"
echo "  Envelope:  effort=xhigh, max_tokens>=64000, thinking=adaptive"
echo ""

claude --settings "$SETTINGS_FILE" "${CLAUDE_ARGS[@]}"
