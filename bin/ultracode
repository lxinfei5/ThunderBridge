#!/usr/bin/env bash
# UltraCode-Shim launcher for macOS / Linux / WSL.
# Windows users: use windows\Start-UltraCode.ps1 instead.
#
# Starts proxy.py, points Claude Code at it with gateway model discovery
# enabled, seeds the discovery cache, runs `claude`, then stops the proxy on
# exit. Your normal Claude Code install is untouched (session-scoped --settings
# + env only).
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROXY="$REPO/proxy.py"
CONFIG="$REPO/config.json"
CONFIG_EXAMPLE="$REPO/config.example.json"
ENV_FILE="$REPO/ultracode.env"
BASE_STATE="${XDG_STATE_HOME:-$HOME/.local/state}/ultracode-shim"
SETTINGS="$BASE_STATE/ultracode_settings.json"
PID_FILE="$BASE_STATE/proxy.pid"
LOG_FILE="$BASE_STATE/proxy.log"

PY="$(command -v python3 || command -v python || true)"
[[ -n "$PY" ]] || { echo "Python 3 not found." >&2; exit 1; }
command -v claude >/dev/null 2>&1 || { echo "claude CLI not found - npm i -g @anthropic-ai/claude-code" >&2; exit 1; }

mkdir -p "$BASE_STATE"

# Config: copy from the example on first run.
if [[ ! -f "$CONFIG" ]]; then
  cp "$CONFIG_EXAMPLE" "$CONFIG"
  echo "Created config.json from config.example.json - edit it to keep the models you have (and add your keys)."
fi

# Load optional ultracode.env (gitignored) for ${VAR} expansion in routes.
if [[ -f "$ENV_FILE" ]]; then
  set -a; # shellcheck disable=SC1090
  . "$ENV_FILE"; set +a
fi

# Resolve port + upstream from config.json (env overrides win).
PORT="${UC_LISTEN_PORT:-$("$PY" -c 'import json,sys;c=json.load(open(sys.argv[1]));print(int((c.get("proxy") or {}).get("listen_port") or 8141))' "$CONFIG" 2>/dev/null || echo 8141)}"
UPSTREAM="${UC_UPSTREAM:-$("$PY" -c 'import json,sys;c=json.load(open(sys.argv[1]));print((c.get("proxy") or {}).get("anthropic_upstream") or "https://api.anthropic.com")' "$CONFIG" 2>/dev/null || echo https://api.anthropic.com)}"
BASE_URL="http://127.0.0.1:${PORT}"

# Session settings (ultracode + discovery env).
cat > "$SETTINGS" <<JSON
{
  "ultracode": true,
  "model": "claude-opus-4-8",
  "env": {
    "ANTHROPIC_BASE_URL": "$BASE_URL",
    "CLAUDE_CODE_WORKFLOWS": "1",
    "CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY": "1"
  }
}
JSON

health_ok() {
  "$PY" - "$BASE_URL" <<'PY' >/dev/null 2>&1
import json,sys,urllib.request
with urllib.request.urlopen(sys.argv[1].rstrip('/')+'/healthz',timeout=2) as r:
    sys.exit(0 if json.loads(r.read()).get('ok') else 1)
PY
}

start_proxy() {
  if health_ok; then return 0; fi
  echo "Starting UltraCode proxy on $BASE_URL -> $UPSTREAM ..."
  UC_CONFIG="$CONFIG" UC_LISTEN_PORT="$PORT" UC_UPSTREAM="$UPSTREAM" UC_LOG="$LOG_FILE" \
    "$PY" "$PROXY" >>"$LOG_FILE" 2>&1 &
  echo $! > "$PID_FILE"
  for _ in $(seq 1 40); do health_ok && return 0; sleep 0.25; done
  echo "Proxy did not become healthy. Log: $LOG_FILE" >&2
  tail -20 "$LOG_FILE" >&2 || true
  exit 1
}

stop_proxy() {
  [[ -f "$PID_FILE" ]] && kill "$(cat "$PID_FILE" 2>/dev/null)" 2>/dev/null || true
  rm -f "$PID_FILE"
}
trap stop_proxy EXIT

start_proxy

# Seed Claude Code's gateway-models cache from the live proxy so synthesized
# Worker -> entries show on first /model open too.
CFG_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
"$PY" - "$CFG_DIR/cache/gateway-models.json" "$BASE_URL" <<'PY' || true
import json,os,sys,time,urllib.request
cache_f, base = sys.argv[1], sys.argv[2]
os.makedirs(os.path.dirname(cache_f), exist_ok=True)
models=[]
with urllib.request.urlopen(base.rstrip('/')+'/healthz',timeout=2) as r:
    health=json.loads(r.read().decode('utf-8'))
for m in health.get('custom_models') or []:
    if isinstance(m,dict) and m.get('id'):
        models.append({'id':m['id'],'display_name':m.get('display_name',m['id'])})
json.dump({'baseUrl':base,'fetchedAt':int(time.time()*1000),'models':models}, open(cache_f,'w'))
PY

export ANTHROPIC_BASE_URL="$BASE_URL"
export CLAUDE_CODE_WORKFLOWS=1
export CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=1

SELECTED_MODEL=""
SELECTOR="$REPO/scripts/ultracode_selector.py"
if [[ "${UC_SELECTOR:-1}" != "0" && -f "$SELECTOR" ]]; then
  set +e
  SELECTED_MODEL="$(UC_PROXY="$BASE_URL" "$PY" "$SELECTOR")"
  SEL_RC=$?
  set -e
  if [[ $SEL_RC -eq 0 && -n "$SELECTED_MODEL" ]]; then
    echo "Selected orchestrator: $SELECTED_MODEL"
  elif [[ $SEL_RC -eq 1 ]]; then
    echo "Selector cancelled; launching with default model."
    SELECTED_MODEL=""
  else
    echo "Selector unavailable; launching with default model."
    SELECTED_MODEL=""
  fi
fi

HAS_MODEL_ARG=0
for arg in "$@"; do
  if [[ "$arg" == "--model" || "$arg" == --model=* ]]; then HAS_MODEL_ARG=1; fi
done

echo "Launching Claude Code (UltraCode). Use /model anytime to change backend."
if [[ -n "$SELECTED_MODEL" && $HAS_MODEL_ARG -eq 0 ]]; then
  claude --settings "$SETTINGS" --model "$SELECTED_MODEL" "$@"
else
  claude --settings "$SETTINGS" "$@"
fi
