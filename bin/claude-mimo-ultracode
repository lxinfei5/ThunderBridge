#!/usr/bin/env bash
# UltraCode launcher — routes claude-opus-4-8 to MiMo v2.5 Pro via local shim.
set -euo pipefail

PORT="${CLAUDE_MIMO_ULTRACODE_PORT:-18766}"
HOST="${CLAUDE_MIMO_ULTRACODE_HOST:-127.0.0.1}"
BASE_URL="http://${HOST}:${PORT}"
PROXY_DIR="${CLAUDE_MIMO_ULTRACODE_PROXY_DIR:-$HOME/devin-local-proxy}"
SHIM="$PROXY_DIR/byok_oai_shim.py"
MIMO_ENV="${DEVIN_MIMO_ENV:-$HOME/.config/devin/mimo.env}"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/claude-mimo-ultracode"
SETTINGS_FILE="$STATE_DIR/settings.json"
PID_FILE="$STATE_DIR/shim.pid"
LOG_FILE="$STATE_DIR/shim.log"
CLAUDE_BIN="${CLAUDE_BIN:-}"
MIMO_REQUEST_MAX_TOKENS="${DEVIN_MIMO_REQUEST_MAX_TOKENS:-8192}"
MIMO_ENABLE_THINKING="${DEVIN_MIMO_ENABLE_THINKING:-0}"
MIMO_TIMING_LOG="${DEVIN_MIMO_TIMING_LOG:-1}"

mkdir -p "$STATE_DIR"

if [[ ! -f "$SHIM" ]]; then
  echo "[claude-mimo-ultracode] missing shim: $SHIM" >&2
  echo "[claude-mimo-ultracode] set CLAUDE_MIMO_ULTRACODE_PROXY_DIR or install byok_oai_shim.py" >&2
  exit 1
fi

if [[ -f "$MIMO_ENV" ]]; then
  set -a
  # shellcheck disable=SC1090
  . "$MIMO_ENV"
  set +a
fi

if [[ -z "${DEVIN_MIMO_API_KEY:-}" ]]; then
  echo "[claude-mimo-ultracode] missing DEVIN_MIMO_API_KEY; expected it in $MIMO_ENV" >&2
  exit 1
fi

health_ok() {
  python3 - "$BASE_URL" <<'PY' >/dev/null 2>&1
import json, sys, urllib.request
url = sys.argv[1].rstrip('/') + '/healthz'
with urllib.request.urlopen(url, timeout=2) as r:
    data = json.loads(r.read().decode())
if not data.get('ok'):
    raise SystemExit(1)
models = set(data.get('models') or [])
if 'mimo' not in models or 'claude-opus-4-8' not in models:
    raise SystemExit(1)
PY
}

start_shim() {
  if [[ -f "$PID_FILE" ]]; then
    old_pid="$(cat "$PID_FILE" 2>/dev/null || true)"
    if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null && health_ok; then
      return 0
    fi
  fi

  if health_ok; then
    return 0
  fi

  echo "[claude-mimo-ultracode] starting MiMo UltraCode shim on $BASE_URL" >&2
  (
    cd "$PROXY_DIR"
    exec env \
      DEVIN_BYOK_SHIM_HOST="$HOST" \
      DEVIN_BYOK_SHIM_PORT="$PORT" \
      CLAUDE_CODE_ULTRACODE_BACKEND=mimo \
      DEVIN_MIMO_API_KEY="${DEVIN_MIMO_API_KEY:-}" \
      DEVIN_MIMO_BASE="${DEVIN_MIMO_BASE:-https://token-plan-sgp.xiaomimimo.com/v1}" \
      DEVIN_MIMO_MODEL="${DEVIN_MIMO_MODEL:-mimo-v2.5-pro}" \
      DEVIN_MIMO_MAX_OUTPUT_TOKENS="${DEVIN_MIMO_MAX_OUTPUT_TOKENS:-131072}" \
      DEVIN_MIMO_REQUEST_MAX_TOKENS="$MIMO_REQUEST_MAX_TOKENS" \
      DEVIN_MIMO_ENABLE_THINKING="$MIMO_ENABLE_THINKING" \
      DEVIN_MIMO_TIMING_LOG="$MIMO_TIMING_LOG" \
      DEVIN_BYOK_SHIM_LOG_FLUSH=1 \
      python3 "$SHIM" --host "$HOST" --port "$PORT"
  ) >>"$LOG_FILE" 2>&1 &
  echo $! > "$PID_FILE"

  for _ in {1..40}; do
    if health_ok; then
      return 0
    fi
    sleep 0.25
  done

  echo "[claude-mimo-ultracode] shim did not become healthy; log: $LOG_FILE" >&2
  tail -40 "$LOG_FILE" >&2 || true
  exit 1
}

write_settings() {
  cat > "$SETTINGS_FILE" <<'JSON'
{
  "ultracode": true
}
JSON
}

find_claude() {
  if [[ -n "$CLAUDE_BIN" ]]; then
    printf '%s\n' "$CLAUDE_BIN"
    return 0
  fi
  if command -v claude >/dev/null 2>&1; then
    command -v claude
    return 0
  fi
  local win_npm="${APPDATA:-/mnt/c/Users/$USER/AppData/Roaming}/npm/claude"
  if [[ -x "$win_npm" ]]; then
    printf '%s\n' "$win_npm"
    return 0
  fi
  echo "[claude-mimo-ultracode] could not find claude; set CLAUDE_BIN=/path/to/claude" >&2
  exit 1
}

start_shim
write_settings
CLAUDE_REAL="$(find_claude)"

unset CLAUDE_CODE_EFFORT_LEVEL
export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-sk-ant-dummy}"
export ANTHROPIC_BASE_URL="$BASE_URL"
export CLAUDE_CODE_WORKFLOWS="${CLAUDE_CODE_WORKFLOWS:-1}"
export WSLENV="ANTHROPIC_API_KEY:ANTHROPIC_BASE_URL:CLAUDE_CODE_WORKFLOWS${WSLENV:+:$WSLENV}"

if [[ "${1:-}" == "--smoke" ]]; then
  shift
  exec "$CLAUDE_REAL" --print --model claude-opus-4-8 --settings "$SETTINGS_FILE" "${*:-Reply with exactly: MIMO_ULTRACODE_OK}"
fi

exec "$CLAUDE_REAL" --model claude-opus-4-8 --settings "$SETTINGS_FILE" "$@"
